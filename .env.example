# URL de connexion complète à la base de données (utilisée par le back-end Node.js)
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@database:5432/YOUR_DB

# Nom de la base de données PostgreSQL
POSTGRES_DB=your_db_name

# Utilisateur PostgreSQL
POSTGRES_USER=your_db_user

# Mot de passe PostgreSQL — ne jamais commiter la valeur réelle
POSTGRES_PASSWORD=your_db_password
